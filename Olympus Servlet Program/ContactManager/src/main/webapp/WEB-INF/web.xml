<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>AddContact</servlet-name>
        <servlet-class>com.contact.controller.AddContactServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddContact</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewContact</servlet-name>
        <servlet-class>com.contact.controller.ViewContactServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ViewContact</servlet-name>
        <url-pattern>/view</url-pattern>
    </servlet-mapping>

</web-app>