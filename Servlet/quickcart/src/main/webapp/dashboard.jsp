<%@ page language="java" contentType="text/html; charset=UTF-8" %>
<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<nav class="navbar navbar-dark bg-dark">
    <div class="container-fluid">
        <span class="navbar-brand">QuickCart Dashboard</span>
    </div>
</nav>

<div class="container mt-4">

    <h2 class="mb-4 text-success">Welcome to Dashboard</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Laptop</h5>
                <p>₹60,000</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Mobile</h5>
                <p>₹20,000</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Headphones</h5>
                <p>₹2,000</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Adapter</h5>
                <p>₹1,500</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Televisiom</h5>
                <p>₹35,000</p>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card p-3 shadow">
                <h5>Air-Conditioner</h5>
                <p>₹40,000</p>
            </div>
        </div>

    </div>

</div>

</body>
</html>